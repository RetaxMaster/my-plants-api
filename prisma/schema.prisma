generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Task {
  WATER
  FERTILIZE
  REPOT
  ROTATE
  CLEAN_LEAVES
  MIST
  PROGRESS
}

enum CareEventType {
  DONE
  POSTPONED
  SYMPTOM
}

enum ProgressHealth {
  SICK // "Enferma"
  POOR // "Mal"
  GOOD // "Buena"
  EXCELLENT // "Excelente"
}

enum LightType {
  DIRECT
  BRIGHT_INDIRECT
  MEDIUM
  LOW
}

enum HumidityCharacter {
  DRY
  NORMAL
  HUMID
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(USER)
  ownerId      String   @unique @map("owner_id")
  owner        Owner    @relation(fields: [ownerId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
}

model RevokedToken {
  jti       String   @id
  expiresAt DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("revoked_tokens")
}

model Owner {
  id     String  @id @default(cuid())
  name   String
  cities City[]
  places Place[]
  plants Plant[]
  user   User?

  @@map("owners")
}

model City {
  id        String  @id @default(cuid())
  ownerId   String  @map("owner_id")
  owner     Owner   @relation(fields: [ownerId], references: [id])
  name      String
  latitude  Float
  longitude Float
  timezone  String
  isPrimary Boolean @default(false) @map("is_primary")
  places    Place[]

  @@index([ownerId])
  @@map("cities")
}

model Place {
  id                String             @id @default(cuid())
  ownerId           String             @map("owner_id")
  owner             Owner              @relation(fields: [ownerId], references: [id])
  cityId            String             @map("city_id")
  city              City               @relation(fields: [cityId], references: [id])
  name              String
  indoor            Boolean
  lightType         LightType          @map("light_type")
  climateControlled Boolean            @default(false) @map("climate_controlled")
  humidityCharacter HumidityCharacter? @map("humidity_character")
  indoorTempMinC    Float?             @map("indoor_temp_min_c")
  indoorTempMaxC    Float?             @map("indoor_temp_max_c")
  airflow           String?            @map("airflow") // airflowEnum slug (still|some|breezy); null = neutral
  plants            Plant[]

  @@index([ownerId])
  @@index([cityId])
  @@map("places")
}

model Species {
  slug           String    @id
  scientificName String    @unique @map("scientific_name")
  record         Json
  blogpost       Blogpost? // 1:1 back-relation (business rule: every species has exactly one)
  plants         Plant[]

  @@map("species")
}

model Blogpost {
  slug        String   @id // == speciesSlug for species guides; derived from titleEs for free-form
  status      Int      @default(0) // 0 = DRAFT, 1 = PUBLISHED (BlogpostStatus)
  speciesSlug String?  @unique @map("species_slug") // 1:1 with Species; null = free-form post
  species     Species? @relation(fields: [speciesSlug], references: [slug], onDelete: SetNull, onUpdate: Cascade)

  titleEs   String  @map("title_es")
  titleEn   String? @map("title_en")
  excerptEs String  @map("excerpt_es") @db.Text
  excerptEn String? @map("excerpt_en") @db.Text
  bodyEs    String  @map("body_es") @db.Text
  bodyEn    String? @map("body_en") @db.Text

  coverImageUrl       String? @map("cover_image_url")
  coverImageObjectKey String? @map("cover_image_object_key") // R2 key, kept for later deletion
  coverImagePrompt    String? @map("cover_image_prompt") @db.Text // OG/cover generation prompt (engine-authored, admin-only)
  youtubeUrl          String? @map("youtube_url")
  ctaLink             String? @map("cta_link")
  ctaLabelEs          String? @map("cta_label_es")
  ctaLabelEn          String? @map("cta_label_en")

  createdByUserId String?   @map("created_by_user_id") // provenance only, NOT an access boundary
  publishedAt     DateTime? @map("published_at") // set when status first becomes PUBLISHED
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([status, publishedAt])
  @@map("blogposts")
}

model MediaAsset {
  id              String   @id @default(cuid())
  imageUrl        String   @map("image_url")
  imageObjectKey  String   @map("image_object_key") // R2 key, for deletion
  filename        String // original client filename (display only)
  sizeBytes       Int      @map("size_bytes") // stored (compressed webp) size
  width           Int?
  height          Int?
  createdByUserId String?  @map("created_by_user_id") // provenance only
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("media_assets")
}

model Plant {
  id          String   @id @default(cuid())
  ownerId     String   @map("owner_id")
  owner       Owner    @relation(fields: [ownerId], references: [id])
  placeId     String   @map("place_id")
  place       Place    @relation(fields: [placeId], references: [id])
  speciesSlug String   @map("species_slug")
  species     Species  @relation(fields: [speciesSlug], references: [slug])
  nickname    String?
  acquiredOn  DateTime @map("acquired_on") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")

  coverImageUrl       String? @map("cover_image_url")
  coverImageObjectKey String? @map("cover_image_object_key") // R2 key, kept for replace/delete

  events          CareEvent[]
  adjustments     PlantTaskAdjustment[]
  overrides       TaskOverride[]
  dueCache        DueCache[]
  progressEntries PlantProgressEntry[]
  frequencies     PlantTaskFrequency[]
  profile         PlantProfile?
  doctorSessions  KnowledgeChatSession[]

  @@index([ownerId])
  @@index([placeId])
  @@map("plants")
}

// A plant's optional physical profile — a 1:1 side table (one row per plant, created lazily on the
// first PATCH). Enum-valued columns store the Spec-1 slug as a plain String: the Zod enum in
// @retaxmaster/my-plants-species-schema is the single source of truth, so the DB never re-declares
// the vocabulary. Cascade-deletes with its plant.
model PlantProfile {
  plantId        String   @id @map("plant_id")
  windowDistance String?  @map("window_distance") // windowDistanceEnum slug
  growLight      Boolean? @map("grow_light")
  potType        String?  @map("pot_type") // potTypeEnum slug
  potSizeCm      Int?     @map("pot_size_cm")
  hasDrainage    Boolean? @map("has_drainage")
  soilMix        String?  @map("soil_mix") // soilMixEnum slug
  growthHabit    String?  @map("growth_habit") // growthHabitEnum slug
  ageMonths      Int?     @map("age_months")
  nearHeater     Boolean? @map("near_heater")
  updatedAt      DateTime @updatedAt @map("updated_at")
  plant          Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("plant_profiles")
}

model CareEvent {
  id         String        @id @default(cuid())
  plantId    String        @map("plant_id")
  plant      Plant         @relation(fields: [plantId], references: [id])
  task       Task
  type       CareEventType
  occurredOn DateTime      @map("occurred_on") @db.Date
  payload    Json?
  createdAt  DateTime      @default(now()) @map("created_at")
  // Pairs a PROGRESS event to its progress entry — set ONLY on PROGRESS events (spec §3.3). @unique: exactly
  // one paired event per entry. SetNull so deleting the entry never blocks; but the delete flow (Spec 2)
  // removes the paired event conditionally BEFORE the entry, so a null-FK stray never lingers.
  progressEntryId String?              @unique @map("progress_entry_id")
  progressEntry   PlantProgressEntry?  @relation(fields: [progressEntryId], references: [id], onDelete: SetNull)

  @@index([plantId, task])
  @@map("care_events")
}

model PlantTaskAdjustment {
  id         String   @id @default(cuid())
  plantId    String   @map("plant_id")
  plant      Plant    @relation(fields: [plantId], references: [id])
  task       Task
  multiplier Float    @default(1.0)
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([plantId, task])
  @@map("plant_task_adjustments")
}

model TaskOverride {
  id        String   @id @default(cuid())
  plantId   String   @map("plant_id")
  plant     Plant    @relation(fields: [plantId], references: [id])
  task      Task
  nextDueOn DateTime @map("next_due_on") @db.Date

  @@unique([plantId, task])
  @@map("task_overrides")
}

model DueCache {
  id         String   @id @default(cuid())
  plantId    String   @map("plant_id")
  plant      Plant    @relation(fields: [plantId], references: [id])
  task       Task
  nextDueOn  DateTime @map("next_due_on") @db.Date
  computedAt DateTime @default(now()) @map("computed_at")

  @@unique([plantId, task])
  @@map("due_caches")
}

model PlantProgressEntry {
  id           String         @id @default(cuid())
  plantId      String         @map("plant_id")
  plant        Plant          @relation(fields: [plantId], references: [id])
  occurredOn   DateTime       @map("occurred_on") @db.Date // the journal date (can backdate)
  health       ProgressHealth
  observations String?        @db.Text
  sizeCm       Int?           @map("size_cm")
  tags         Json? // string[] of catalog keys (validated at the DTO/service, Phase 3)
  createdAt    DateTime       @default(now()) @map("created_at")

  photos    PlantProgressPhoto[]
  careEvent  CareEvent?

  @@index([plantId, occurredOn])
  @@map("plant_progress_entries")
}

model PlantProgressPhoto {
  id             String             @id @default(cuid())
  entryId        String             @map("entry_id")
  entry          PlantProgressEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  // NULLABLE now: a photo row exists BEFORE it has an R2 object. NON-NULL only when status = READY.
  imageUrl       String?            @map("image_url")
  imageObjectKey String?            @map("image_object_key") // R2 key, persisted for later deletion
  // Per-photo processing state. Default READY for deploy-window compat (§3.1/§7): the OLD synchronous code
  // inserts already-uploaded rows with no `status`, and READY makes those correctly terminal. New code
  // ALWAYS writes status='PENDING' explicitly on the async path.
  status         PhotoStatus        @default(READY)
  inboxPath      String?            @map("inbox_path")        // absolute path to the staged raw bytes; null once consumed/expired
  originalName   String?            @map("original_name")     // client filename, for the "IMG_6402.JPG failed" label
  attempts       Int                @default(0)               // count of FAILED processing attempts (not claims)
  nextAttemptAt  DateTime?          @map("next_attempt_at")   // earliest a retry may be re-claimed (native Date; NULL = eligible now)
  claimToken     String?            @map("claim_token")       // set when a worker claims; cleared on terminal transition (§4.5)
  claimedAt      DateTime?          @map("claimed_at")        // when the current claim started; stale claims are recoverable (§4.5)
  failureKind    PhotoFailureKind?  @map("failure_kind")      // drives retryability
  failureCode    String?            @map("failure_code")      // the failureCode union, e.g. 'image_too_large' — surfaced in the read shape
  sortOrder      Int                @default(0) @map("sort_order")
  createdAt      DateTime           @default(now()) @map("created_at")
  // @default(now()) as well as @updatedAt: the DB-level CURRENT_TIMESTAMP(3) default lets a DEPLOY-WINDOW
  // insert from the OLD synchronous client (which omits updated_at entirely) still succeed — mirroring the
  // status='READY' default's deploy-window role (§3.1/§7). @updatedAt keeps the app bumping it on every
  // write. Declaring the default here also keeps `prisma migrate diff` empty against 0020's DDL.
  updatedAt      DateTime           @default(now()) @updatedAt @map("updated_at")

  @@index([entryId])
  @@index([status, nextAttemptAt]) // the worker sweeps eligible rows by status
  @@map("plant_progress_photos")
}

enum PhotoStatus {
  PENDING
  PROCESSING
  RECOVERING
  READY
  FAILED
}

enum PhotoFailureKind {
  transient
  permanent
}

model PlantTaskFrequency {
  id           String   @id @default(cuid())
  plantId      String   @map("plant_id")
  plant        Plant    @relation(fields: [plantId], references: [id])
  task         Task
  intervalDays Int      @map("interval_days") // explicit base interval, replaces the species value
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([plantId, task])
  @@map("plant_task_frequencies")
}

model ScheduledMove {
  id           String   @id @default(cuid())
  ownerId      String   @map("owner_id")
  targetCityId String   @map("target_city_id")
  moveOn       DateTime @map("move_on") @db.Date
  applied      Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([ownerId])
  @@map("scheduled_moves")
}

enum KnowledgeChatRunStatus {
  QUEUED
  // The launch lease: the run has claimed the session's active slot and a process is being spawned for
  // it, but no pid is recorded yet. It exists so a deploy drain can tell "nothing is running, safe to
  // reload" apart from "a process is a millisecond away from existing" — a window QUEUED cannot express.
  LAUNCHING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

// The lifecycle of a Plant Doctor write proposal. PENDING is the only state the owner can act on; every
// other value is terminal (Plant Doctor Copilot spec §5).
enum DoctorProposalStatus {
  PENDING
  APPROVED
  DECLINED
  EXPIRED
  FAILED
}

// Why applying a proposal failed, in the sanitized vocabulary the owner and the agent are allowed to see.
// Deliberately coarse: a raw DB/driver error text is not something a plant-scoped agent gets to read back.
enum DoctorProposalFailureCode {
  VALIDATION
  NOT_FOUND
  OWNERSHIP
  CONFLICT
  INTERNAL
}

// The delivery state of the one `[system]` message a run may carry. It is what makes delivery
// AT-MOST-ONCE and durable across a crash: CONSUMED (claimed by a run that has not started yet),
// DELIVERED (the agent actually received it), RESTORED (the run died before delivery, so the message
// went back to the session), DROPPED (unrecoverable — recorded rather than silently lost).
enum SystemMessageState {
  CONSUMED
  DELIVERED
  RESTORED
  DROPPED
}

// Under whose authority a plant write happened. The whole point of the audit table: after the fact, an
// owner-made change and a doctor-proposed one must be distinguishable forever.
enum WriteOrigin {
  OWNER
  DOCTOR
}

// A Plant Doctor write PROPOSAL: the operations the agent wants applied, plus the immutable snapshot of
// the values they would overwrite. Creating one writes NOTHING to plant data — applying it does, and only
// after the effective owner approves.
model DoctorWriteProposal {
  id        String               @id @default(uuid())
  sessionId String               @map("session_id")
  session   KnowledgeChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // The run that filed it. A proposal is sealed to BOTH its session and its run so a doctor token cannot
  // file against a different session of the same plant — which matters because THAT session might have
  // Skip Permissions on, silently auto-approving it.
  runId     String               @map("run_id")
  plantId   String               @map("plant_id")
  ownerId   String               @map("owner_id")
  // The validated operations array, serialized. Text, not JSON columns: MariaDB 10.x aliases JSON to
  // LONGTEXT anyway, and the shape's authority is the Zod union, not the DB.
  operations String              @map("operations") @db.MediumText
  // The BEFORE values, captured at propose time and never rewritten. This is what makes the owner's
  // consent bind to what they were actually shown.
  snapshot   String              @map("snapshot") @db.MediumText
  summary    String              @db.Text
  status     DoctorProposalStatus @default(PENDING)
  // 'PENDING' while pending; null once resolved. Same null-exempt unique trick as KnowledgeChatRun's
  // activeKey — with @@unique([sessionId, pendingKey]) it DB-enforces "at most ONE pending proposal per
  // session" atomically, instead of hoping a read-then-write wins the race.
  pendingKey String?             @map("pending_key")
  autoApproved Boolean           @default(false) @map("auto_approved")
  failureCode   DoctorProposalFailureCode? @map("failure_code")
  failureReason String?                    @map("failure_reason")
  createdAt        DateTime  @default(now()) @map("created_at")
  resolvedAt       DateTime? @map("resolved_at")
  resolvedByUserId String?   @map("resolved_by_user_id")

  @@unique([sessionId, pendingKey])
  @@index([plantId])
  @@index([runId])
  @@map("doctor_write_proposals")
}

// Append-only: one row per APPLIED operation, recording who wrote it and under what authority. Written
// inside the same transaction as the write it describes, so the fact and its record commit together.
model PlantWriteAudit {
  id      String      @id @default(uuid())
  plantId String      @map("plant_id")
  ownerId String      @map("owner_id")
  origin  WriteOrigin
  // A historical identifier ONLY — deliberately NOT a relation and NOT cascaded. The audit log must
  // outlive the chat session (and therefore the proposal) that produced it (spec §7.4).
  proposalId    String? @map("proposal_id")
  actorUserId   String? @map("actor_user_id")
  operationType String  @map("operation_type")
  targetTable   String  @map("target_table")
  targetId      String? @map("target_id")
  payloadJson   String  @map("payload_json") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([plantId, createdAt])
  @@map("plant_write_audit")
}

// What a chat session IS: the admin Knowledge Engine chat, or a per-plant Plant Doctor diagnosis. One
// shared session/run machinery serves both, routed by this discriminator (Plant Doctor Spec 3 §3.1).
enum ChatSessionKind {
  KNOWLEDGE
  DOCTOR
}

model KnowledgeChatSession {
  id String @id @default(cuid())
  // WHICH AGENT owns this conversation ('claude' | 'codex' — the agents-realtime `AgentProvider` wire
  // vocabulary, stored verbatim so the value we persist is the value we send on /execute). Chosen when
  // the conversation is created and LOCKED once a run proves a real session exists, because a Claude
  // session and a Codex thread cannot read each other's history — switching agents mid-conversation
  // would make the screen lie about what the agent remembers. Deliberately a String, not an enum: the
  // protocol package owns this vocabulary, and a DB enum would fork it.
  provider          String             @default("claude")
  // The AGENT's own session id (Claude's UUID / Codex's thread id) — null until the first run inits it.
  // Renamed from `claude_session_id` in the agents-realtime 1.0.0 migration: with two agents the old
  // name was a lie for half the rows.
  providerSessionId String?            @unique @map("provider_session_id")
  // The run that currently holds the right to SEAL this conversation (set when a run claims the session's
  // active slot). It exists so the seal can be a SINGLE conditional UPDATE — `WHERE provider_session_id IS
  // NULL AND pending_run_id = <the reporting run>` — instead of a read-then-write. Checking "is this the
  // newest run?" before writing is a TOCTOU: an abandoned run can pass the check and then seal the
  // conversation a retry has already claimed, pinning it to the agent the user just walked away from.
  pendingRunId      String?            @map("pending_run_id")
  title             String // first ~160 chars of the first prompt
  createdByUserId   String?            @map("created_by_user_id") // provenance only, NOT an access boundary
  // KNOWLEDGE (the admin KE chat) | DOCTOR (a per-plant diagnosis). Defaults KNOWLEDGE so pre-migration
  // inserts (which set none of these) stay valid during `prisma migrate deploy` (Plant Doctor Spec 3 §3.1).
  kind              ChatSessionKind    @default(KNOWLEDGE)
  plantId           String?            @map("plant_id") // non-null ⇔ kind = DOCTOR; the pinned plant
  ownerId           String?            @map("owner_id") // the owning owner — the DOCTOR access boundary
  // Deleting a plant cascade-removes its DOCTOR session ROWS; the live run + FS logs/workspaces are handled
  // by the orchestrated cleanup (Spec 3 §3.1) — the cascade is the row half only.
  plant             Plant?             @relation(fields: [plantId], references: [id], onDelete: Cascade)
  // Skip Permissions: when true, this session's proposals auto-approve. It is per-session and never
  // global, and it records WHO turned it on and WHEN — an owner-granted standing consent has to be
  // attributable, not an anonymous flag.
  skipPermissions            Boolean   @default(false) @map("skip_permissions")
  skipPermissionsSetByUserId String?   @map("skip_permissions_set_by_user_id")
  skipPermissionsSetAt       DateTime? @map("skip_permissions_set_at")
  // The one `[system]` message waiting to be handed to this session's NEXT run. It parks on the session
  // (not the run) precisely because no run may exist yet when the owner resolves a proposal.
  pendingSystemMessage           String? @map("pending_system_message") @db.Text
  pendingSystemMessageProposalId String? @map("pending_system_message_proposal_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  runs              KnowledgeChatRun[]
  proposals         DoctorWriteProposal[]

  @@index([kind, plantId])
  @@index([ownerId])
  @@map("knowledge_chat_sessions")
}

model KnowledgeChatRun {
  id        String               @id @default(cuid())
  sessionId String               @map("session_id")
  session   KnowledgeChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // The agent this run was LAUNCHED with. It lives on the run, not just the session, because the run is
  // the only thing that knows which agent actually produced the session id it reports back: sealing the
  // session's `provider` and `provider_session_id` from the SAME run, atomically, is what makes it
  // impossible for those two columns to end up describing different agents (which a retry on a second
  // agent, racing a late callback from the first, could otherwise do).
  provider  String               @default("claude")
  // The AGENT SESSION this run actually took part in (recorded when the run reports it). It is what makes
  // "does this run belong to that conversation's memory?" a FACT rather than an inference. A run that never
  // reached the agent — cancelled or killed before it opened a session — keeps NULL here: it contributed
  // nothing to the agent's memory, its log holds no session, and claiming it as part of the conversation
  // makes the engine fail the whole history read.
  providerSessionId String?      @map("provider_session_id")
  // Whether THIS run was executed by an engine that records the line above. It is what turns a NULL
  // `providerSessionId` from ambiguous into decisive: with it TRUE, null PROVES the run never reached the
  // agent (an orphan, safely excluded from history); with it FALSE, null means only "we never tracked it"
  // — a run that may well have reached the agent, so the conversation must fall back to the agent's own
  // transcript rather than quietly dropping that turn. Two very different facts wear the same NULL, and
  // conflating them is a silent loss of history.
  sessionTracked    Boolean      @default(true) @map("session_tracked")
  // The user's message for this turn — NULL on a COMMAND turn, because a command is not text: it is an
  // instruction to the agent's runtime and it travels in its own field, never inside a prompt. It is ALSO
  // NULL on a SYSTEM-MESSAGE-ONLY turn (a decline-triggered run, whose whole input is the host's notice in
  // `systemMessageText`) — legal since the agents-realtime 3.0.x adoption, and the reason migration 0024
  // widened the DB CHECK from a strict prompt-XOR-command to "at least one input, prompt and command still
  // mutually exclusive". The alternative — keeping this NOT NULL and storing the
  // literal "/compact" — is a value that LOOKS like data and IS a sentinel, and it is the open door for
  // some later code path to re-send it as a prompt. That is the precise bug agents-realtime 2.0.0 exists
  // to delete, so we do not reintroduce it in our own table.
  prompt      String?               @db.Text
  // The command's bare name ("compact", "model", "postman:docs" — colons are legal, Claude namespaces its
  // plugin skills) and its raw argument string, verbatim as typed. Set together, and only on a command turn.
  commandName String?               @map("command_name")
  commandArgs String?               @db.Text @map("command_args")
  status        KnowledgeChatRunStatus @default(QUEUED)
  // 'ACTIVE' while the run is non-terminal; null once terminal. With @@unique([sessionId, activeKey])
  // and MySQL/MariaDB's null-exempt unique semantics, this DB-enforces "at most ONE active run per
  // session" atomically — a concurrent second active insert hits a unique violation (→ 409). The
  // service/orchestrator clear it to null on every terminal transition, freeing the slot.
  activeKey     String?                @map("active_key")
  pid           Int?
  procStartTime String?                @map("proc_start_time")
  exitCode      Int?                   @map("exit_code")
  error         String?                @db.Text
  startedAt     DateTime?              @map("started_at")
  finishedAt    DateTime?              @map("finished_at")
  createdAt     DateTime               @default(now()) @map("created_at")
  // The `[system]` message THIS run claimed from its session, and what became of it. Claiming moves the
  // text off the session and onto the run in the SAME transaction that queues the run, so a crash can
  // never both lose the message and leave it pending.
  systemMessageText       String?             @map("system_message_text") @db.Text
  systemMessageProposalId String?             @map("system_message_proposal_id")
  systemMessageState      SystemMessageState? @map("system_message_state")
  tickets       KnowledgeChatTicket[]

  @@unique([sessionId, activeKey])
  @@index([sessionId])
  @@map("knowledge_chat_runs")
}

model KnowledgeChatTicket {
  id         String           @id @default(cuid())
  runId      String           @map("run_id")
  run        KnowledgeChatRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  tokenHash  String           @unique @map("token_hash") // sha256(raw); raw returned once
  expiresAt  DateTime         @map("expires_at")
  consumedAt DateTime?        @map("consumed_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  @@map("knowledge_chat_tickets")
}
