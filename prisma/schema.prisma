generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Task {
  WATER
  FERTILIZE
  REPOT
  ROTATE
  CLEAN_LEAVES
  MIST
  PROGRESS
}

enum CareEventType {
  DONE
  POSTPONED
  SYMPTOM
}

enum ProgressHealth {
  SICK      // "Enferma"
  POOR      // "Mal"
  GOOD      // "Buena"
  EXCELLENT // "Excelente"
}

enum LightType {
  DIRECT
  BRIGHT_INDIRECT
  MEDIUM
  LOW
}

enum HumidityCharacter {
  DRY
  NORMAL
  HUMID
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(USER)
  ownerId      String   @unique @map("owner_id")
  owner        Owner    @relation(fields: [ownerId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  @@map("users")
}

model RevokedToken {
  jti       String   @id
  expiresAt DateTime @map("expires_at")
  @@index([expiresAt])
  @@map("revoked_tokens")
}

model Owner {
  id     String  @id @default(cuid())
  name   String
  cities City[]
  places Place[]
  plants Plant[]
  user   User?

  @@map("owners")
}

model City {
  id        String  @id @default(cuid())
  ownerId   String  @map("owner_id")
  owner     Owner   @relation(fields: [ownerId], references: [id])
  name      String
  latitude  Float
  longitude Float
  timezone  String
  isPrimary Boolean @default(false) @map("is_primary")
  places    Place[]

  @@index([ownerId])
  @@map("cities")
}

model Place {
  id                String            @id @default(cuid())
  ownerId           String            @map("owner_id")
  owner             Owner             @relation(fields: [ownerId], references: [id])
  cityId            String            @map("city_id")
  city              City              @relation(fields: [cityId], references: [id])
  name              String
  indoor            Boolean
  lightType         LightType         @map("light_type")
  climateControlled Boolean           @default(false) @map("climate_controlled")
  humidityCharacter HumidityCharacter? @map("humidity_character")
  indoorTempMinC    Float?            @map("indoor_temp_min_c")
  indoorTempMaxC    Float?            @map("indoor_temp_max_c")
  plants            Plant[]

  @@index([ownerId])
  @@index([cityId])
  @@map("places")
}

model Species {
  slug           String  @id
  scientificName String  @unique @map("scientific_name")
  record         Json
  // Human-readable Markdown brief (the "blogpost"), persisted in the DB in both languages.
  briefEn        String? @map("brief_en") @db.Text
  briefEs        String? @map("brief_es") @db.Text
  plants         Plant[]

  @@map("species")
}

model Plant {
  id          String   @id @default(cuid())
  ownerId     String   @map("owner_id")
  owner       Owner    @relation(fields: [ownerId], references: [id])
  placeId     String   @map("place_id")
  place       Place    @relation(fields: [placeId], references: [id])
  speciesSlug String   @map("species_slug")
  species     Species  @relation(fields: [speciesSlug], references: [slug])
  nickname    String?
  acquiredOn  DateTime @db.Date @map("acquired_on")
  createdAt   DateTime @default(now()) @map("created_at")

  events          CareEvent[]
  adjustments     PlantTaskAdjustment[]
  overrides       TaskOverride[]
  dueCache        DueCache[]
  progressEntries PlantProgressEntry[]
  frequencies     PlantTaskFrequency[]

  @@index([ownerId])
  @@index([placeId])
  @@map("plants")
}

model CareEvent {
  id         String        @id @default(cuid())
  plantId    String        @map("plant_id")
  plant      Plant         @relation(fields: [plantId], references: [id])
  task       Task
  type       CareEventType
  occurredOn DateTime      @db.Date @map("occurred_on")
  payload    Json?
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([plantId, task])
  @@map("care_events")
}

model PlantTaskAdjustment {
  id         String   @id @default(cuid())
  plantId    String   @map("plant_id")
  plant      Plant    @relation(fields: [plantId], references: [id])
  task       Task
  multiplier Float    @default(1.0)
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([plantId, task])
  @@map("plant_task_adjustments")
}

model TaskOverride {
  id        String   @id @default(cuid())
  plantId   String   @map("plant_id")
  plant     Plant    @relation(fields: [plantId], references: [id])
  task      Task
  nextDueOn DateTime @db.Date @map("next_due_on")

  @@unique([plantId, task])
  @@map("task_overrides")
}

model DueCache {
  id         String   @id @default(cuid())
  plantId    String   @map("plant_id")
  plant      Plant    @relation(fields: [plantId], references: [id])
  task       Task
  nextDueOn  DateTime @db.Date @map("next_due_on")
  computedAt DateTime @default(now()) @map("computed_at")

  @@unique([plantId, task])
  @@map("due_caches")
}

model PlantProgressEntry {
  id           String         @id @default(cuid())
  plantId      String         @map("plant_id")
  plant        Plant          @relation(fields: [plantId], references: [id])
  occurredOn   DateTime       @db.Date @map("occurred_on") // the journal date (can backdate)
  health       ProgressHealth
  observations String?        @db.Text
  sizeCm       Int?           @map("size_cm")
  tags         Json?          // string[] of catalog keys (validated at the DTO/service, Phase 3)
  createdAt    DateTime       @default(now()) @map("created_at")

  photos       PlantProgressPhoto[]

  @@index([plantId, occurredOn])
  @@map("plant_progress_entries")
}

model PlantProgressPhoto {
  id             String             @id @default(cuid())
  entryId        String             @map("entry_id")
  entry          PlantProgressEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  imageUrl       String             @map("image_url")
  imageObjectKey String             @map("image_object_key") // R2 key, persisted for later deletion
  sortOrder      Int                @default(0) @map("sort_order")
  createdAt      DateTime           @default(now()) @map("created_at")

  @@index([entryId])
  @@map("plant_progress_photos")
}

model PlantTaskFrequency {
  id           String   @id @default(cuid())
  plantId      String   @map("plant_id")
  plant        Plant    @relation(fields: [plantId], references: [id])
  task         Task
  intervalDays Int      @map("interval_days") // explicit base interval, replaces the species value
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([plantId, task])
  @@map("plant_task_frequencies")
}

model ScheduledMove {
  id           String   @id @default(cuid())
  ownerId      String   @map("owner_id")
  targetCityId String   @map("target_city_id")
  moveOn       DateTime @db.Date @map("move_on")
  applied      Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([ownerId])
  @@map("scheduled_moves")
}
