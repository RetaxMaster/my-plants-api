DB_HOST=localhost
DB_PORT=3306
DB_USER=myplants
DB_PASSWORD=123
DB_NAME=myplants
PORT=8000
# Network interface the HTTP server binds to. Leave unset (defaults to 0.0.0.0) for local dev.
# In production set HOST=127.0.0.1 so the API is reachable only by the co-located web BFF.
# HOST=0.0.0.0
# Primary garden city (used for weather + canonical timezone). Overridable via the API.
DEFAULT_CITY_TZ=America/Mexico_City
# Browser origin allowed by CORS (the web app). Defaults to http://localhost:8001 if unset.
WEB_ORIGIN=http://localhost:8001
# Auth (app runtime only; never commit real values)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=30d
# Hard absolute session cap in days (re-login forced this long after first login, regardless of
# activity). Optional — defaults to 90.
SESSION_ABSOLUTE_MAX_DAYS=90
# Image storage on Cloudflare R2 (OPTIONAL — image upload is disabled until ALL are set).
# Never commit real values; only .env.example is tracked (Security rule). The connection is built
# from these SEPARATE vars, never a hand-authored connection string.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Admin knowledge-engine chat (embedded realtime engine + isolated claude cwd)
# Port the in-process realtime engine binds on 127.0.0.1 (browser connects here directly in v1).
KNOWLEDGE_CHAT_ENGINE_PORT=8010
# Shared secret gating the engine's own /execute control plane (never commit a real value).
KNOWLEDGE_CHAT_ENGINE_SECRET=change-me-to-a-long-random-string
# Set to false to boot the API without starting the engine (used by the e2e/CI env).
KNOWLEDGE_CHAT_ENGINE_ENABLED=true
# Host-owned NDJSON transcript dir (gitignored; created on boot). MUST be ABSOLUTE: the engine spawns
# `claude` in KNOWLEDGE_ENGINE_CWD and redirects the log via a shell, so a relative path would resolve
# against the wrong cwd and the redirect would fail before claude runs. (Code also resolves it to an
# absolute path defensively, but set it absolute here to be explicit.)
KNOWLEDGE_CHAT_LOG_DIR=/absolute/path/to/my-plants-api/storage/knowledge-chat
# Isolated knowledge-engine checkout the engine runs `claude` in (a path with NO parent CLAUDE.md
# except the checkout's own — see docs/local-development.md).
KNOWLEDGE_ENGINE_CWD=/absolute/path/to/isolated-knowledge-engine
# Path to the claude CLI (defaults to `claude` on PATH).
CLAUDE_BIN=claude
