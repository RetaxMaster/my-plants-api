DB_HOST=localhost
DB_PORT=3306
DB_USER=myplants
DB_PASSWORD=123
DB_NAME=myplants
PORT=8000
# Network interface the HTTP server binds to. Leave unset (defaults to 0.0.0.0) for local dev.
# In production set HOST=127.0.0.1 so the API is reachable only by the co-located web BFF.
# HOST=0.0.0.0
# Primary garden city (used for weather + canonical timezone). Overridable via the API.
DEFAULT_CITY_TZ=America/Mexico_City
# Browser origin allowed by CORS (the web app). Defaults to http://localhost:8001 if unset.
WEB_ORIGIN=http://localhost:8001
# Auth (app runtime only; never commit real values)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=30d
# Hard absolute session cap in days (re-login forced this long after first login, regardless of
# activity). Optional — defaults to 90.
SESSION_ABSOLUTE_MAX_DAYS=90
# Image storage on Cloudflare R2 (OPTIONAL — image upload is disabled until ALL are set).
# Never commit real values; only .env.example is tracked (Security rule). The connection is built
# from these SEPARATE vars, never a hand-authored connection string.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Async progress-photo pipeline (spec 2026-07-14). Where raw uploaded bytes are STAGED on disk between the
# POST and the in-process worker that decodes/uploads them. Defaults to `storage/photo-inbox` (relative to
# the API cwd) — fine for local dev. In PRODUCTION this MUST be an absolute path OUTSIDE the deploy/build
# tree so a deploy never wipes in-flight bytes (see docs/deploy.md).
PHOTO_INBOX_DIR=storage/photo-inbox
# Free-space floor (MB) on the filesystem holding PHOTO_INBOX_DIR; below it, staging a new photo returns
# 503 photo_storage_busy (the guard against filling the disk during an R2 outage). Default 1024.
INBOX_MIN_FREE_MB=1024

# Admin knowledge-engine chat (embedded agents-realtime engine + isolated agent cwd).
# The engine runs BOTH agents (Claude and Codex); which one runs a conversation is chosen in the UI.
# Port the in-process realtime engine binds on 127.0.0.1 (browser connects here directly in v1).
KNOWLEDGE_CHAT_ENGINE_PORT=8010
# Shared secret gating the engine's own /execute control plane (never commit a real value).
# NOTE: the engine's header is X-Agents-RT-Secret since agents-realtime 1.0.0 (was X-Claude-RT-Secret).
KNOWLEDGE_CHAT_ENGINE_SECRET=change-me-to-a-long-random-string
# Set to false to boot the API without starting the engine (used by the e2e/CI env).
KNOWLEDGE_CHAT_ENGINE_ENABLED=true
# NDJSON transcript dir (gitignored; created on boot). This is the engine's `logRoot`: it REJECTS any run
# whose log path falls outside it. The engine creates each log file itself, exclusively — the API never
# pre-creates one. MUST be ABSOLUTE (the code resolves it defensively, but set it absolute to be explicit).
KNOWLEDGE_CHAT_LOG_DIR=/absolute/path/to/my-plants-api/storage/knowledge-chat
# The engine's DURABLE run index (runId → logPath), required since agents-realtime 1.0.0. It is what lets
# a run survive an API restart (the engine re-adopts the still-alive agent from it), so point it at a
# PERSISTENT, writable, absolute dir — never a tmp dir a reboot wipes.
KNOWLEDGE_CHAT_STATE_DIR=/absolute/path/to/my-plants-api/storage/knowledge-chat-state
# Isolated knowledge-engine checkout the agents run in (a path with NO parent CLAUDE.md / AGENTS.md
# except the checkout's own — see docs/local-development.md).
KNOWLEDGE_ENGINE_CWD=/absolute/path/to/isolated-knowledge-engine
# Paths to the agent CLIs (default to `claude` / `codex` on PATH). An agent that is missing or signed out
# is simply reported unavailable and disabled in the picker — the API still boots.
CLAUDE_BIN=claude
CODEX_BIN=codex
# Codex's sandbox inside that checkout. `danger-full-access` is the DEFAULT and is deliberate: Codex's
# `workspace-write` blocks NETWORK access, and web research is the knowledge engine's whole job. It grants
# Codex exactly the trust Claude already has there (--dangerously-skip-permissions).
KNOWLEDGE_CHAT_CODEX_SANDBOX=danger-full-access

# ── Plant Doctor engine (a SECOND agents-realtime instance, runs in the doctor's checkout) ──
# A per-plant diagnostic agent. DOCTOR-kind sessions run on this engine (cwd = the doctor runtime checkout)
# so they load the doctor's CLAUDE.md/.claude/.codex, isolated from the knowledge engine. It reuses
# CLAUDE_BIN/CODEX_BIN, KNOWLEDGE_CHAT_CODEX_SANDBOX, the run+ticket timeouts, JWT_SECRET, and WEB_ORIGIN.
# The doctor runtime checkout (an isolated clone of my-plants-plant-doctor, OUTSIDE this repo). REQUIRED.
PLANT_DOCTOR_ENGINE_CWD=/absolute/path/to/my-plants-plant-doctor-runtime
# Port the doctor engine binds on 127.0.0.1 (dev 8400; prod 3458, reverse-proxied as the doctor wss subdomain).
PLANT_DOCTOR_CHAT_ENGINE_PORT=8400
# Shared secret gating the doctor engine's /execute control plane (never commit a real value).
PLANT_DOCTOR_CHAT_ENGINE_SECRET=change-me-to-a-long-random-string
# Set to false to boot the API without starting the doctor engine (used by the e2e/CI env).
PLANT_DOCTOR_ENGINE_ENABLED=true
# Doctor run-log dir (the engine's logRoot) — ABSOLUTE, gitignored, created on boot.
PLANT_DOCTOR_LOG_DIR=/absolute/path/to/my-plants-api/storage/plant-doctor
# Doctor engine DURABLE run index + the codexRolesVerified record — PERSISTENT, ABSOLUTE.
PLANT_DOCTOR_STATE_DIR=/absolute/path/to/my-plants-api/storage/plant-doctor-state
# Per-session isolated workspaces (each holds a doctor-context.json + scoped token). In prod point this
# OUTSIDE the deploy/build tree so a deploy never wipes an in-flight diagnosis. ABSOLUTE.
PLANT_DOCTOR_WORKSPACE_ROOT=/absolute/path/to/my-plants-api/storage/plant-doctor-workspaces
# TTL (ms) of the per-run scoped doctor JWT (default 30 min — one run window).
PLANT_DOCTOR_TOKEN_TTL_MS=1800000
